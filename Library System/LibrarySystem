import java.util.*;
class Book{
    String title;
    String author;
    int bookId;
    boolean isIssued;

    Book(String title,String author,int bookId){
        this.title=title;
        this.author=author;
        this.bookId=bookId;
    }

    public void issueBook(){
        if(!isIssued){
            System.out.println(this.title+" Book Issued.");
            this.isIssued=true;
        }else{
            System.out.println("Book already issued");
        }
    }

    public void returnBook(){
        System.out.println(this.title+" Book returned.");
        this.isIssued=false;
    }

    public void displayBook(){
        System.out.println("Title: "+this.title);
        System.out.println("Author: "+this.author);
        System.out.println("Book ID: "+this.bookId);
    }
}
class Library{
    Book[] books = new Book[10];
    int size=0;
    Scanner sn = new Scanner(System.in);

    public void addBook(){
        System.out.println("Enter book title:");
        String title=sn.nextLine();
        System.out.println("Enter book Author:");
        String author=sn.nextLine();
        System.out.println("Enter book Id:");
        int bookId=sn.nextInt();
        sn.nextLine();
        books[size++]=new Book(title,author,bookId);
        System.out.println("Book Added..");
    }

    public void displayBooks(){
        for (int i=0;i<size;i++){
            books[i].displayBook();
        }
    }

    public void issueBookbyId(int id){
        for(int i=0;i<size;i++){
            if(books[i].bookId==id){
                books[i].issueBook();
            }
        }
    }

    public void returnBookbyId(int id){
        for(int i=0;i<size;i++){
            if(books[i].bookId==id){
                books[i].returnBook();
            }
        }
    }

}
public class LibrarySystem extends Library{
    public static void menu(){
    Library lib = new Library();
    Scanner sn = new Scanner(System.in);
    boolean run = true;
        while(run){
            System.out.println("---------Library System--------");
            System.out.println();
            System.out.println("1.Add Book");
            System.out.println("2.DIsplay Books");
            System.out.println("3.Issue Book");
            System.out.println("4.Return Book");
            System.out.println("5.Exit");

            System.out.println("Enter Your Choice:");
            int ch = sn.nextInt();

            switch(ch){
                case 1:
                    lib.addBook();
                    break;
                case 2:
                    lib.displayBooks();
                    break;
                case 3:
                    System.out.println("Enter Book Id To Be Issue:");
                    int id = sn.nextInt();
                    lib.issueBookbyId(id);
                    break;
                case 4:
                    System.out.println("Enter Book Id To Be Return:");
                    id = sn.nextInt();
                    lib.returnBookbyId(id);
                    break;
                case 5:
                    run = false;
                    break;
                default:
                    break;

            }
        }
    }
    public static void main(String args[]){
        menu();
    }
}
